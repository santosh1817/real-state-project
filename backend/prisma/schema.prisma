generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            BigInt         @id @default(autoincrement())
  name          String         @db.VarChar(120)
  email         String         @unique @db.Citext
  passwordHash  String         @map("password_hash")
  phone         String?        @db.VarChar(30)
  role          String         @default("USER") @db.VarChar(20)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  properties    Property[]
  refreshTokens RefreshToken[]
  inquiries     Inquiry[]      @relation("BuyerInquiries")

  @@map("users")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user")
  @@map("refresh_tokens")
}

model Property {
  id           BigInt          @id @default(autoincrement())
  ownerId      BigInt          @map("owner_id")
  title        String          @db.VarChar(180)
  description  String
  city         String          @db.VarChar(80)
  location     String          @db.VarChar(160)
  address      String?
  propertyType String          @map("property_type") @db.VarChar(40)
  listingType  String          @default("sale") @map("listing_type") @db.VarChar(20)
  price        Decimal         @db.Decimal(14, 2)
  bedrooms     Int
  bathrooms    Int
  areaSqft     Int             @map("area_sqft")
  amenities    String[]        @default([])
  status       String          @default("active") @db.VarChar(20)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  owner        User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images       PropertyImage[]
  inquiries    Inquiry[]

  @@index([ownerId], map: "idx_properties_owner_id")
  @@index([status, city, propertyType, bedrooms, price, createdAt(sort: Desc), id(sort: Desc)], map: "idx_properties_active_filters")
  @@index([status, city, propertyType, bedrooms, price], map: "idx_properties_similarity")
  @@map("properties")
}

model PropertyImage {
  id         BigInt   @id @default(autoincrement())
  propertyId BigInt   @map("property_id")
  imageUrl   String   @map("image_url")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId], map: "idx_property_images_property_id")
  @@map("property_images")
}

model Inquiry {
  id         BigInt   @id @default(autoincrement())
  propertyId BigInt   @map("property_id")
  buyerId    BigInt   @map("buyer_id")
  message    String
  phone      String?  @db.VarChar(30)
  status     String   @default("NEW") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer      User     @relation("BuyerInquiries", fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([propertyId, buyerId])
  @@index([buyerId, createdAt(sort: Desc)], map: "idx_inquiries_buyer_created")
  @@map("inquiries")
}
